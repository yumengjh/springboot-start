# 复制为 .env 后按需填写。此文件不会被 Git 提交。

# 本地 SQLite
APP_DATA_DIR=./data
SERVER_PORT=8080

# 第一次启动时创建超级管理员；留空则不创建。
APP_BOOTSTRAP_ADMIN_USERNAME=
APP_BOOTSTRAP_ADMIN_PASSWORD=
# 仅在明确需要恢复本地管理员时设为 true；正常情况下保持 false。
APP_BOOTSTRAP_ADMIN_RESET_PASSWORD=false

# JWT：local 默认可临时生成密钥；生产 postgres profile 必须同时提供私钥和公钥。
# 可直接填 PEM（换行写为 \n），或使用下列文件路径。不要把真实密钥提交到 Git。
APP_JWT_PRIVATE_KEY_PEM=
APP_JWT_PUBLIC_KEY_PEM=
APP_JWT_PRIVATE_KEY_PATH=
APP_JWT_PUBLIC_KEY_PATH=
# 不要在 .env 中设置 APP_JWT_ALLOW_EPHEMERAL_KEY；local 默认允许临时密钥，postgres 默认拒绝。

# 仅当直连来源属于这些 CIDR/IP 时，才解析 X-Forwarded-For。
APP_SECURITY_TRUSTED_PROXIES=

# PostgreSQL profile（启动时使用 SPRING_PROFILES_ACTIVE=postgres）
DB_URL=jdbc:postgresql://localhost:5432/starter
DB_USERNAME=starter
DB_PASSWORD=change-me-before-use

# Compose 使用
POSTGRES_DB=starter
POSTGRES_USER=starter
POSTGRES_PASSWORD=change-me-before-use
APP_PORT=8080
